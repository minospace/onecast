<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oui_background_color"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/grabber" />

    <ImageButton
        android:id="@+id/player_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Close"
        android:src="@drawable/ic_chevron_down" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/player_art"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:background="@drawable/bg_art_placeholder"
            android:contentDescription="@null"
            android:elevation="8dp"
            android:scaleType="centerCrop"
            android:transitionName="player_art" />
    </LinearLayout>

    <TextView
        android:id="@+id/player_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/player_podcast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:gravity="center"
        android:singleLine="true"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/player_position"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/player_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/player_skip_back"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Skip back 15 seconds"
            android:src="@drawable/ic_skip_back" />

        <ImageButton
            android:id="@+id/player_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="28dp"
            android:background="@drawable/bg_play_circle"
            android:contentDescription="Play or pause"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play"
            android:tint="@color/app_on_primary" />

        <ImageButton
            android:id="@+id/player_skip_forward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Skip forward 30 seconds"
            android:src="@drawable/ic_skip_forward" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/player_speed"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_chip"
            android:minWidth="84dp"
            android:paddingHorizontal="18dp"
            android:text="1.0×"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/player_mark_played"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_chip"
            android:drawableStart="@drawable/ic_check"
            android:drawablePadding="6dp"
            android:paddingHorizontal="18dp"
            android:text="Mark played"
            android:textColor="?android:attr/textColorPrimary" />
    </LinearLayout>
</LinearLayout>
