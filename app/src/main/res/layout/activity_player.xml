<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oui_background_color">

    <!-- Artwork-derived gradient wash, drawn full-bleed behind the content. -->
    <View
        android:id="@+id/player_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

<LinearLayout
    android:id="@+id/player_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp">

    <!-- Everything above the title is a single drag-to-dismiss zone. Child click targets
         (the close button) still consume their own touches, so they keep working. -->
    <LinearLayout
        android:id="@+id/player_drag_zone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/grabber" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/player_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:src="@drawable/ic_chevron_down"
                android:tint="?android:attr/textColorSecondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/player_queue"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_queue"
                android:src="@drawable/ic_queue"
                android:tint="?android:attr/textColorSecondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/player_art"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:background="@drawable/bg_art_placeholder"
                android:contentDescription="@null"
                android:elevation="8dp"
                android:scaleType="centerCrop"
                android:transitionName="player_art" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/player_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:ellipsize="end"
        android:gravity="center"
        android:lineSpacingMultiplier="1.05"
        android:maxLines="2"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/player_podcast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:gravity="center"
        android:singleLine="true"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/player_chapter"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_chip"
        android:drawableStart="@drawable/ic_chapters"
        android:drawablePadding="8dp"
        android:drawableTint="?android:attr/textColorPrimary"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:maxWidth="280dp"
        android:paddingHorizontal="16dp"
        android:singleLine="true"
        android:textAllCaps="false"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="1. Introduction" />

    <SeekBar
        android:id="@+id/player_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/player_position"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/player_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/player_skip_back"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Skip back 15 seconds"
            android:src="@drawable/ic_skip_back"
            android:tint="?android:attr/textColorPrimary" />

        <ImageButton
            android:id="@+id/player_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="28dp"
            android:background="@drawable/bg_play_circle"
            android:contentDescription="Play or pause"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play"
            android:tint="@color/app_on_primary" />

        <ImageButton
            android:id="@+id/player_skip_forward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Skip forward 30 seconds"
            android:src="@drawable/ic_skip_forward"
            android:tint="?android:attr/textColorPrimary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/player_speed"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_chip"
            android:minWidth="84dp"
            android:paddingHorizontal="18dp"
            android:text="1.0×"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/player_mark_played"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_chip"
            android:drawableStart="@drawable/ic_check"
            android:drawablePadding="6dp"
            android:drawableTint="?android:attr/textColorPrimary"
            android:paddingHorizontal="18dp"
            android:text="Mark played"
            android:textColor="?android:attr/textColorPrimary" />
    </LinearLayout>
</LinearLayout>
</FrameLayout>
