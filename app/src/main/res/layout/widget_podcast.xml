<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen widget. All colours are concrete resources (see values/colors.xml) rather than
     ?android:attr/* theme attributes, because a widget is inflated against the launcher's theme,
     not the app's. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_card"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_art"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_art_placeholder"
            android:contentDescription="@null"
            android:padding="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_widget_logo" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/widget_empty_title"
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@string/widget_empty_subtitle"
                android:textColor="@color/widget_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/widget_skip_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_skip_back"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_replay"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_widget_play"
            android:contentDescription="@string/widget_play_pause"
            android:padding="13dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play"
            android:tint="@color/app_on_primary"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/widget_skip_forward"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_skip_forward"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_forward"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_time_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            tools:text="12:04" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="10dp"
            android:layout_weight="1"
            android:max="1000"
            android:progressDrawable="@drawable/mini_progress" />

        <TextView
            android:id="@+id/widget_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
