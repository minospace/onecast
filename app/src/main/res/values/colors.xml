<resources>
    <!-- One UI signature accent blue -->
    <color name="app_primary">#FF0381FE</color>
    <color name="app_on_primary">#FFFFFFFF</color>
    <color name="app_divider">#33808080</color>
    <color name="app_art_placeholder">#22808080</color>
    <!-- Semantic alias for the One UI content-panel background (oui_background_color), so app
         code can reach it through the app R class (non-transitive R hides library resources).
         The reference resolves the library's own day/night variant at runtime. -->
    <color name="app_content_background">@color/oui_background_color</color>
    <!-- oneui-design's ToolbarLayout paints its app-bar header and the content card's rounded
         corners directly from these library colour resources (a theme-attribute override has no
         effect — the library reads the resource id, not ?attr/roundedCornerColor). Overriding them
         here (app resources win over the AAR's) collapses the One UI two-tone header/content seam
         into one flat colour. oui_background_color already resolves the right day/night shade, so
         the day and night variants of these can all point at it from this single (default) folder
         — no values-night override needed (and one there with no default declaration trips lint's
         MissingDefaultResource on lintVitalRelease). -->
    <color name="sesl_round_and_bgcolor_light">@color/oui_background_color</color>
    <color name="sesl_round_and_bgcolor_dark">@color/oui_background_color</color>
    <color name="sesl_action_bar_background_color_light">@color/oui_background_color</color>
    <color name="sesl_action_bar_background_color_dark">@color/oui_background_color</color>
    <!-- Mini-player card surface; adapts via the day/night override in values-night. -->
    <color name="app_mini_player_surface">#FFFFFFFF</color>
    <!-- Subtle pill background for the speed / mark-played chips. -->
    <color name="app_chip_surface">#14808080</color>
    <!-- One UI 8.5 grouped-preference card surface, used only on the Settings screen. It sits a
         shade off the flat window background (app_content_background) so each PreferenceCategory
         reads as a discrete rounded card floating on the continuous surface — a lighter card on
         the near-black dark background (values-night), a faint grey card on the near-white light
         background here. This is the newer One UI card look, not the old grey window band the
         "no grey panel" rule removed, so it stays scoped to Settings. -->
    <color name="app_settings_card">#FFF1F1F3</color>
</resources>
