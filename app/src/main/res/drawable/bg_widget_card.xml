<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded One UI card the whole widget sits on. Concrete surface + divider colours (day/night
     qualified) so it renders identically regardless of the host launcher's theme. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/app_mini_player_surface" />
    <corners android:radius="24dp" />
    <stroke
        android:width="1dp"
        android:color="@color/app_divider" />
</shape>
